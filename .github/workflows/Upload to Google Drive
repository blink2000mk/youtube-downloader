name: Upload to Google Drive
on:
  workflow_dispatch:
    inputs:
      folder_id:
        description: 'Google Drive Folder ID'
        required: true
jobs:
  upload:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Setup gdrive
        run: |
          wget -O gdrive https://docs.gdrive3rdparty.com/gdrive-linux-x64
          chmod +x gdrive
          sudo mv gdrive /usr/local/bin/

      - name: Authenticate and Upload
        env:
          GDRIVE_AUTH_TOKEN: ${{ secrets.GDRIVE_AUTH_TOKEN }}
        run: |
          if [ -z "$GDRIVE_AUTH_TOKEN" ]; then
            echo "No auth token found, attempting initial setup..."
            # این دستور لینکی را چاپ می‌کند. شما باید آن را در مرورگر باز کنید.
            gdrive about
          else
            echo "$GDRIVE_AUTH_TOKEN" > token.json
            gdrive about --config ./
          fi
          # آپلود فایل‌های پوشه youtube
          gdrive upload --recursive --parent ${{ github.event.inputs.folder_id }} youtube/
